# ==============================================
# en-practice-be — Example Environment
# Copy this file to .env and fill in real values
# DO NOT commit .env to version control!
# ==============================================

# ---- Docker Hub Image ----
DOCKER_HUB_IMAGE=swpts2/en-practice-be
APP_VERSION=latest

# ---- App Port ----
APP_PORT=8080

# ---- PostgreSQL ----
POSTGRES_DB=en_practice
POSTGRES_USER=en_practice
POSTGRES_PASSWORD=change-me

# ---- JWT ----
JWT_SECRET=change-me
JWT_EXPIRATION=604800000

# ---- Firebase Admin SDK ----
FIREBASE_CONFIG_BASE64=change-me

# ---- OpenClaw Gateway ----
OPENCLAW_GATEWAY_URL=http://openclaw-gateway:18789
OPENCLAW_GATEWAY_TOKEN=change-me
OPENCLAW_GATEWAY_RESPONSE_TIMEOUT_MS=60000
OPENCLAW_GATEWAY_READ_TIMEOUT_MS=60000
OPENCLAW_GATEWAY_WRITE_TIMEOUT_MS=60000
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

# ---- Cloudflared ----
CLOUDFLARED_CONFIG_DIR=/home/<user>/.cloudflared

# ---- Google Cloud TTS ----
TTS_API_KEY=change-me
TTS_VOICE_NAME=en-US-Neural2-J
TTS_LANGUAGE_CODE=en-US

# ---- Backblaze S3 ----
BACKBLAZE_S3_ENDPOINT=https://s3.us-west-004.backblazeb2.com
BACKBLAZE_S3_REGION=us-west-004
BACKBLAZE_S3_ACCESS_KEY_ID=change-me
BACKBLAZE_S3_SECRET_ACCESS_KEY=change-me
BACKBLAZE_S3_BUCKET_NAME=en-practice
BACKBLAZE_S3_WORKER_SHARED_SECRET=change-me

# ---- CORS ----
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ---- Custom conversation max turn ----
CUSTOM_SPEAKING_CONVERSATION_MAX_USER_TURNS=10

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_SSL_ENABLED=false
SPRING_CACHE_TYPE=redis

# ---- Kafka ----
SPRING_KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_INTERNAL_HOST=kafka
KAFKA_INTERNAL_PORT=9092
KAFKA_EXTERNAL_HOST=localhost
KAFKA_EXTERNAL_PORT=9094

# ---- Cloudflare ----
CLOUDFLARED_CONFIG_DIR=/home/<user>/.cloudflared
