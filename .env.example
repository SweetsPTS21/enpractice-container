# ==============================================
# en-practice backup server environment example
# Copy to .env and fill in real values
# ==============================================

# ---- Docker Hub Image ----
DOCKER_HUB_IMAGE=swpts2/en-practice-be
APP_VERSION=latest

# ---- App Port ----
APP_PORT=8080

# ---- PostgreSQL ----
POSTGRES_DB=en_practice
POSTGRES_USER=en_practice
POSTGRES_PASSWORD=replace-with-postgres-password

# ---- JWT ----
JWT_SECRET=replace-with-strong-jwt-secret
JWT_EXPIRATION=604800000

# ---- Firebase Admin SDK ----
FIREBASE_CONFIG_BASE64=replace-with-base64-firebase-service-account-json

# ---- OpenClaw Gateway ----
OPENCLAW_GATEWAY_URL=http://openclaw-gateway:18789
OPENCLAW_GATEWAY_TOKEN=replace-with-openclaw-gateway-token
OPENCLAW_GATEWAY_RESPONSE_TIMEOUT_MS=60000
OPENCLAW_GATEWAY_READ_TIMEOUT_MS=60000
OPENCLAW_GATEWAY_WRITE_TIMEOUT_MS=60000
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

# ---- OpenClaw Runtime ----
# Create openclaw/config/openclaw.json from openclaw/config/openclaw.json.example

# ---- Google Cloud TTS ----
TTS_API_KEY=replace-with-google-tts-api-key
TTS_VOICE_NAME=en-US-Neural2-J
TTS_LANGUAGE_CODE=en-US

# ---- Backblaze S3 ----
BACKBLAZE_S3_ENDPOINT=https://s3.us-west-004.backblazeb2.com
BACKBLAZE_S3_REGION=us-west-004
BACKBLAZE_S3_ACCESS_KEY_ID=replace-with-backblaze-key-id
BACKBLAZE_S3_SECRET_ACCESS_KEY=replace-with-backblaze-secret
BACKBLAZE_S3_BUCKET_NAME=en-practice
BACKBLAZE_S3_WORKER_SHARED_SECRET=replace-with-worker-shared-secret

# ---- CORS ----
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ---- Custom conversation max turn ----
CUSTOM_SPEAKING_CONVERSATION_MAX_USER_TURNS=10

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_SSL_ENABLED=false
SPRING_CACHE_TYPE=redis

# ---- Kafka ----
SPRING_KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_INTERNAL_HOST=kafka
KAFKA_INTERNAL_PORT=9092
KAFKA_EXTERNAL_HOST=kafka.swpts.site
KAFKA_EXTERNAL_PORT=9094
